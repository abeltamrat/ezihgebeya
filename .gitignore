# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
.claude/

# Local environment and secrets
.env
.env.*
*.local.php

# Dependency/build folders
vendor/
node_modules/
dist/
build/
frontend/dist/

# Generated Vite SPA build copied into the PHP web root for /app/*.
# Keep app/*.php source files tracked; only ignore the generated frontend shell/assets.
app/index.html
app/assets/
app/favicon.svg
app/icons.svg

# Runtime/generated files
*.log
database/outbox.log
backups/
*.sql.gz
*.zip

# User/private uploads; keep seeded/demo public uploads in source
uploads/payments/
uploads/ui/
uploads/ar-models/

# Verification documents and payment proofs — real user-uploaded sensitive files, never committed
protected_uploads/

# Generated file cache (app/cache.php) — regenerated on demand
storage/cache/*.json
dev_router.php
